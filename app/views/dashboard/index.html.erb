<style>
  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f4f6f9;
  }

  .dashboard-container {
    display: flex;
    min-height: 100vh;
  }

  .sidebar {
    width: 240px;
    background: #1f2937;
    color: white;
    padding: 25px 15px;
  }

  .sidebar h2 {
    text-align: center;
    margin-bottom: 40px;
  }

  .sidebar a {
    display: block;
    color: white;
    text-decoration: none;
    padding: 14px 15px;
    margin: 8px 0;
    border-radius: 6px;
  }

  .sidebar a:hover {
    background: #374151;
  }

  .main-content {
    flex: 1;
    padding: 30px;
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
  }

  .topbar h1 {
    margin: 0;
    color: #1f2937;
  }

  .welcome {
    color: #6b7280;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .card {
    background: white;
    padding: 25px;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }

  .card h3 {
    margin: 0;
    color: #6b7280;
    font-size: 16px;
  }

  .card .number {
    font-size: 32px;
    font-weight: bold;
    margin-top: 15px;
    color: #111827;
  }

  .quick-actions {
    margin-top: 35px;
    background: white;
    padding: 25px;
    border-radius: 10px;
  }

  .quick-actions h2 {
    margin-top: 0;
  }

  .action-buttons {
    display: flex;
    gap: 15px;
  }

  .action-buttons a {
    text-decoration: none;
    padding: 12px 20px;
    border-radius: 6px;
    background: #2563eb;
    color: white;
  }

  .action-buttons a:hover {
    background: #1d4ed8;
  }

  @media (max-width: 800px) {
    .sidebar {
      width: 180px;
    }

    .cards {
      grid-template-columns: 1fr;
    }

    .action-buttons {
      flex-direction: column;
    }
  }
</style>

<div class="dashboard-container">

  <div class="sidebar">

    <h2>Payroll System</h2>

    <%= link_to "Dashboard", root_path %>

    <%= link_to "Employees", employees_path %>

    <%= link_to "Add Employee", new_employee_path %>

    <%= link_to "Salary Slips", salary_slips_path %>

    <%= link_to "Create Salary Slip", new_salary_slip_path %>

  </div>


  <div class="main-content">

    <div class="topbar">

      <div>
        <h1>Dashboard</h1>
        <p class="welcome">
          Welcome to Employee Salary Management System
        </p>
      </div>

      <div>
        <strong>Admin</strong>
      </div>

    </div>


    <div class="cards">

      <div class="card">

        <h3>Total Employees</h3>

        <div class="number">
          <%= Employee.count %>
        </div>

      </div>


      <div class="card">

        <h3>Total Salary Slips</h3>

        <div class="number">
          <%= SalarySlip.count %>
        </div>

      </div>


      <div class="card">

        <h3>Total Payroll</h3>

        <div class="number">
          ₹ <%= SalarySlip.sum(:net_salary) %>
        </div>

      </div>

    </div>


    <div class="quick-actions">

      <h2>Quick Actions</h2>

      <div class="action-buttons">

        <%= link_to "Add New Employee",
            new_employee_path %>

        <%= link_to "Create Salary Slip",
            new_salary_slip_path %>

        <%= link_to "View Salary Slips",
            salary_slips_path %>

      </div>

    </div>

  </div>

</div>
