<div class="login-container">
  <div class="login-box">
    <h1>Employee Login</h1>

    <% if flash[:alert] %>
      <p class="error-message"><%= flash[:alert] %></p>
    <% end %>

    <%= form_with url: employee_login_path, method: :post, data: { turbo: false } do |form| %>      <div class="form-group">
        <%= form.label :employee_id, "Employee ID" %>
        <%= form.text_field :employee_id, placeholder: "Enter Employee ID" %>
      </div>

      <div class="form-group">
        <%= form.label :password, "Password" %>
        <%= form.password_field :password, placeholder: "Enter Password" %>
      </div>

      <%= form.submit "Login", class: "login-button" %>
    <% end %>
  </div>
</div>