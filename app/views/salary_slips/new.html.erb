<h1>Create Salary Slip</h1>

<%= form_with model: @salary_slip do |form| %>

  <div>
    <%= form.label :employee_id, "Employee ID" %><br>
    <%= form.collection_select :employee_id,
        Employee.all,
        :id,
        :employee_id,
        prompt: "Select Employee" %>
  </div>

  <br>

  <div>
    <%= form.label :month %><br>
    <%= form.text_field :month %>
  </div>

  <br>

  <div>
    <%= form.label :year %><br>
    <%= form.number_field :year %>
  </div>

  <hr>

  <h2>Earnings</h2>

  <div>
    <%= form.label :basic_salary, "Basic Salary" %><br>
    <%= form.number_field :basic_salary,
        step: 0.01,
        id: "basic_salary" %>
  </div>

  <br>

  <div>
    <%= form.label :hra, "HRA (40%)" %><br>
    <%= form.number_field :hra,
        step: 0.01,
        readonly: true,
        id: "hra" %>
  </div>

  <br>

  <div>
    <%= form.label :transport_allowance, "Transport Allowance (10%)" %><br>
    <%= form.number_field :transport_allowance,
        step: 0.01,
        readonly: true,
        id: "transport_allowance" %>
  </div>

  <br>

  <div>
    <%= form.label :medical_allowance, "Medical Allowance (5%)" %><br>
    <%= form.number_field :medical_allowance,
        step: 0.01,
        readonly: true,
        id: "medical_allowance" %>
  </div>

  <br>

  <div>
    <%= form.label :special_allowance, "Special Allowance (5%)" %><br>
    <%= form.number_field :special_allowance,
        step: 0.01,
        readonly: true,
        id: "special_allowance" %>
  </div>

  <br>

  <div>
    <%= form.label :other_allowances, "Other Allowances (5%)" %><br>
    <%= form.number_field :other_allowances,
        step: 0.01,
        readonly: true,
        id: "other_allowances" %>
  </div>

  <br>

  <div>
    <%= form.label :gross_salary, "Gross Salary" %><br>
    <%= form.number_field :gross_salary,
        step: 0.01,
        readonly: true,
        id: "gross_salary" %>
  </div>

  <hr>

  <h2>Deductions</h2>

  <div>
    <%= form.label :pf, "Provident Fund (12%)" %><br>
    <%= form.number_field :pf,
        step: 0.01,
        readonly: true,
        id: "pf" %>
  </div>

  <br>

  <div>
    <%= form.label :professional_tax, "Professional Tax" %><br>
    <%= form.number_field :professional_tax,
        step: 0.01,
        readonly: true,
        id: "professional_tax" %>
  </div>

  <br>

  <div>
    <%= form.label :tds, "TDS (5%)" %><br>
    <%= form.number_field :tds,
        step: 0.01,
        readonly: true,
        id: "tds" %>
  </div>

  <br>

  <div>
    <%= form.label :loan_deduction, "Loan Deduction" %><br>
    <%= form.number_field :loan_deduction,
        step: 0.01,
        id: "loan_deduction" %>
  </div>

  <br>

  <div>
    <%= form.label :other_deductions, "Other Deductions" %><br>
    <%= form.number_field :other_deductions,
        step: 0.01,
        id: "other_deductions" %>
  </div>

  <br>

  <div>
    <%= form.label :deductions, "Total Deductions" %><br>
    <%= form.number_field :deductions,
        step: 0.01,
        readonly: true,
        id: "deductions" %>
  </div>

  <hr>

  <h2>Final Salary</h2>

  <div>
    <%= form.label :net_salary, "Net Salary" %><br>
    <%= form.number_field :net_salary,
        step: 0.01,
        readonly: true,
        id: "net_salary" %>
  </div>

  <br>

<%= form.submit "Create Salary Slip" %>

<% end %>

<script>

  function calculateSalary() {

    let basic = parseFloat(document.getElementById("basic_salary").value) || 0;

    let hra = basic * 0.40;
    let transport = basic * 0.10;
    let medical = basic * 0.05;
    let special = basic * 0.05;
    let otherAllowances = basic * 0.05;

    let pf = basic * 0.12;
    let professionalTax = 200;
    let tds = basic * 0.05;

    let loan = parseFloat(document.getElementById("loan_deduction").value) || 0;
    let otherDeductions = parseFloat(document.getElementById("other_deductions").value) || 0;

    document.getElementById("hra").value = hra.toFixed(2);
    document.getElementById("transport_allowance").value = transport.toFixed(2);
    document.getElementById("medical_allowance").value = medical.toFixed(2);
    document.getElementById("special_allowance").value = special.toFixed(2);
    document.getElementById("other_allowances").value = otherAllowances.toFixed(2);

    document.getElementById("pf").value = pf.toFixed(2);
    document.getElementById("professional_tax").value = professionalTax.toFixed(2);
    document.getElementById("tds").value = tds.toFixed(2);

    let totalAllowances =
      hra +
      transport +
      medical +
      special +
      otherAllowances;

    let grossSalary = basic + totalAllowances;

    let totalDeductions =
      pf +
      professionalTax +
      tds +
      loan +
      otherDeductions;

    let netSalary = grossSalary - totalDeductions;

    document.getElementById("gross_salary").value = grossSalary.toFixed(2);
    document.getElementById("deductions").value = totalDeductions.toFixed(2);
    document.getElementById("net_salary").value = netSalary.toFixed(2);
  }


  document.querySelectorAll("input[type='number']").forEach(function(input) {
    input.addEventListener("input", calculateSalary);
  });

</script>
