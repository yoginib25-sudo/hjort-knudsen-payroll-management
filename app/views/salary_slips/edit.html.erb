<style>
  .salary-form {
    max-width: 1000px;
    margin: 30px auto;
    font-family: Arial, sans-serif;
  }

  .salary-form h1 {
    text-align: center;
    color:#1f2937;
  }

  .salary-form h2 {
    margin-top: 25px;
    border-bottom: 2px solid #333;
    padding-bottom: 8px;
    color:#374151;
  }

  .form-section {
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:20px;
    margin-bottom:20px;
  }


  .form-field {
    display:flex;
    flex-direction:column;
  }


  .form-field label {
    font-weight:bold;
    margin-bottom:6px;
  }


  .form-field input,
  .form-field select {

    padding:9px;
    font-size:15px;
    border:1px solid #ccc;
    border-radius:6px;

  }


  .readonly-field {

    background:#f1f1f1;

  }


  .full-width {

    grid-column:1/-1;

  }



  .submit-button {

    margin-top:25px;
    padding:12px 25px;
    font-size:16px;
    background:#16a34a;
    color:white;
    border:none;
    border-radius:6px;
    cursor:pointer;

  }


  .submit-button:hover {

    background:#15803d;

  }



  .back-button {

    display:inline-block;
    margin-top:20px;
    text-decoration:none;
    background:#374151;
    color:white;
    padding:10px 20px;
    border-radius:6px;

  }



  @media(max-width:768px){

    .form-section{

      grid-template-columns:1fr;

    }

  }

</style>



<div class="salary-form">


<h1>
Edit Salary Slip
</h1>



<%= form_with model: @salary_slip do |form| %>



<!-- Employee Details -->

<h2>
Employee Details
</h2>


<div class="form-section">


<div class="form-field">


<%= form.label :employee_id,"Employee ID" %>


<%= form.collection_select :employee_id,
Employee.all,
:id,
:employee_id,
prompt:"Select Employee" %>


</div>



<div class="form-field">

<%= form.label :month %>

<%= form.text_field :month %>

</div>



<div class="form-field">

<%= form.label :year %>

<%= form.number_field :year %>

</div>



</div>






<!-- Earnings -->


<h2>
Earnings
</h2>



<div class="form-section">



<div class="form-field">

<%= form.label :basic_salary,"Basic Salary" %>

<%= form.number_field :basic_salary,
step:0.01,
id:"basic_salary" %>

</div>




<div class="form-field">

<%= form.label :hra,"HRA (40%)" %>

<%= form.number_field :hra,
step:0.01,
readonly:true,
class:"readonly-field",
id:"hra" %>

</div>




<div class="form-field">

<%= form.label :transport_allowance,"Transport Allowance (10%)" %>

<%= form.number_field :transport_allowance,
step:0.01,
readonly:true,
class:"readonly-field",
id:"transport_allowance" %>

</div>




<div class="form-field">

<%= form.label :medical_allowance,"Medical Allowance (5%)" %>

<%= form.number_field :medical_allowance,
step:0.01,
readonly:true,
class:"readonly-field",
id:"medical_allowance" %>

</div>




<div class="form-field">

<%= form.label :special_allowance,"Special Allowance (5%)" %>

<%= form.number_field :special_allowance,
step:0.01,
readonly:true,
class:"readonly-field",
id:"special_allowance" %>

</div>




<div class="form-field">

<%= form.label :other_allowances,"Other Allowances (5%)" %>

<%= form.number_field :other_allowances,
step:0.01,
readonly:true,
class:"readonly-field",
id:"other_allowances" %>

</div>




<div class="form-field full-width">

<%= form.label :gross_salary,"Gross Salary" %>


<%= form.number_field :gross_salary,
step:0.01,
readonly:true,
class:"readonly-field",
id:"gross_salary" %>


</div>



</div>








<!-- Deductions -->


<h2>
Deductions
</h2>



<div class="form-section">



<div class="form-field">

<%= form.label :pf,"Provident Fund (12%)" %>


<%= form.number_field :pf,
step:0.01,
readonly:true,
class:"readonly-field",
id:"pf" %>


</div>





<div class="form-field">


<%= form.label :professional_tax,"Professional Tax" %>


<%= form.number_field :professional_tax,
step:0.01,
readonly:true,
class:"readonly-field",
id:"professional_tax" %>


</div>





<div class="form-field">


<%= form.label :tds,"TDS (5%)" %>


<%= form.number_field :tds,
step:0.01,
readonly:true,
class:"readonly-field",
id:"tds" %>


</div>





<div class="form-field">


<%= form.label :loan_deduction,"Loan Deduction" %>


<%= form.number_field :loan_deduction,
step:0.01,
id:"loan_deduction" %>


</div>





<div class="form-field">


<%= form.label :other_deductions,"Other Deductions" %>


<%= form.number_field :other_deductions,
step:0.01,
id:"other_deductions" %>


</div>





<div class="form-field">


<%= form.label :deductions,"Total Deductions" %>


<%= form.number_field :deductions,
step:0.01,
readonly:true,
class:"readonly-field",
id:"deductions" %>


</div>



</div>







<!-- Final Salary -->


<h2>
Final Salary
</h2>



<div class="form-section">


<div class="form-field">


<%= form.label :net_salary,"Net Salary" %>


<%= form.number_field :net_salary,
step:0.01,
readonly:true,
class:"readonly-field",
id:"net_salary" %>


</div>



</div>







<%= form.submit "Update Salary Slip",
class:"submit-button" %>



<% end %>




<br>


<%= link_to "← Back to Salary Slips",
salary_slips_path,
class:"back-button" %>



</div>







<script>


function calculateSalary(){


let basic =
parseFloat(document.getElementById("basic_salary").value) || 0;


let hra = basic * 0.40;

let transport = basic * 0.10;

let medical = basic * 0.05;

let special = basic * 0.05;

let otherAllowances = basic * 0.05;



let pf = basic * 0.12;

let professionalTax = 200;

let tds = basic * 0.05;



let loan =
parseFloat(document.getElementById("loan_deduction").value) || 0;



let otherDeductions =
parseFloat(document.getElementById("other_deductions").value) || 0;




document.getElementById("hra").value = hra.toFixed(2);

document.getElementById("transport_allowance").value = transport.toFixed(2);

document.getElementById("medical_allowance").value = medical.toFixed(2);

document.getElementById("special_allowance").value = special.toFixed(2);

document.getElementById("other_allowances").value = otherAllowances.toFixed(2);



document.getElementById("pf").value = pf.toFixed(2);

document.getElementById("professional_tax").value = professionalTax.toFixed(2);

document.getElementById("tds").value = tds.toFixed(2);




let gross =
basic +
hra +
transport +
medical +
special +
otherAllowances;



let deductions =
pf +
professionalTax +
tds +
loan +
otherDeductions;



let net =
gross - deductions;



document.getElementById("gross_salary").value=gross.toFixed(2);

document.getElementById("deductions").value=deductions.toFixed(2);

document.getElementById("net_salary").value=net.toFixed(2);



}



document.querySelectorAll("input[type='number']")
.forEach(function(input){

input.addEventListener("input",calculateSalary);

});



</script>