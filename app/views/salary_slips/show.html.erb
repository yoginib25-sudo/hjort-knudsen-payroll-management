<style>
  body {
    background: #f4f6f9;
    font-family: Arial, sans-serif;
  }

  .payslip {
    width: 850px;
    margin: 30px auto;
    background: white;
    padding: 35px;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.15);
  }

  /* COMPANY HEADER */

  .company-header {
    text-align: center;
    border-bottom: 3px solid #1f2937;
    padding-bottom: 20px;
  }

  .company-logo {
    width: 100px;
    height: auto;
    margin-bottom: 8px;
  }

  .company-header h1 {
    margin: 0;
    color: #1f2937;
    font-size: 28px;
  }

  .company-header p {
    margin: 8px 0;
    color: #555;
  }

  /* SALARY SLIP TITLE */

  .payslip-title {
    text-align: center;
    margin: 25px 0;
  }

  .payslip-title h2 {
    display: inline-block;
    background: #1f2937;
    color: white;
    padding: 10px 35px;
    margin: 0;
  }

  /* EMPLOYEE DETAILS */

  .employee-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 18px;
    row-gap: 6px;
    background: #f8fafc;
    padding: 10px 14px;
    margin-bottom: 25px;
  }

  .employee-details > div {
    display: flex;
    align-items: center;
    padding: 5px 8px;
    min-height: 30px;
  }

  .employee-details strong {
    width: 120px;
    color: #666;
    font-size: 14px;
  }

  .employee-details span {
    color: #111;
    font-size: 14px;
  }

  /* SALARY SECTION */

  .salary-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 25px;
  }

  .salary-box {
    border: 1px solid #ddd;
  }

  .salary-box h3 {
    background: #1f2937;
    color: white;
    margin: 0;
    padding: 12px;
  }

  .salary-row {
    display: flex;
    justify-content: space-between;
    padding: 10px 12px;
    border-bottom: 1px solid #eee;
  }

  .total-row {
    font-weight: bold;
    background: #f3f4f6;
  }

  /* NET SALARY */

  .net-salary {
    margin-top: 25px;
    background: #e5e7eb;
    padding: 18px;
    text-align: center;
    font-size: 24px;
    font-weight: bold;
  }

  /* FOOTER */

  .footer {
    margin-top: 35px;
    text-align: center;
    color: #777;
    font-size: 13px;
  }

  /* BUTTONS */

  .action-buttons {
    text-align: center;
    margin: 20px;
  }

  .back-button {
    display: inline-block;
    padding: 12px 25px;
    background: #6b7280;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    margin-right: 10px;
  }

  .back-button:hover {
    background: #4b5563;
  }

  .print-button {
    display: inline-block;
  }

  .print-button button {
    padding: 12px 25px;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
  }

  /* MOBILE */

  @media (max-width: 700px) {
    .payslip {
      width: auto;
      margin: 15px;
      padding: 20px;
    }

    .employee-details,
    .salary-section {
      grid-template-columns: 1fr;
    }

    .action-buttons {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .back-button {
      margin-right: 0;
    }

    .print-button {
      display: block;
    }

    .print-button button {
      width: 100%;
    }
  }

  /* PRINT */

  @media print {
    .action-buttons {
      display: none;
    }

    body {
      background: white;
    }

    .payslip {
      box-shadow: none;
      margin: 0;
    }
  }
</style>


<div class="payslip">

  <!-- COMPANY HEADER -->

  <div class="company-header">

    <%= image_tag "company_logo.png", class: "company-logo" %>

    <h1>Hjort Knudsen Pvt. Ltd.</h1>

  </div>


  <!-- SALARY SLIP TITLE -->

  <div class="payslip-title">

    <h2>SALARY SLIP</h2>

  </div>


  <!-- EMPLOYEE DETAILS -->

  <div class="employee-details">

    <div>
      <strong>Employee ID:</strong>
      <span><%= @salary_slip.employee.employee_id %></span>
    </div>

    <div>
      <strong>Employee Name:</strong>
      <span><%= @salary_slip.employee.name %></span>
    </div>

    <div>
      <strong>Department:</strong>
      <span><%= @salary_slip.employee.department %></span>
    </div>

    <div>
      <strong>Email:</strong>
      <span><%= @salary_slip.employee.email %></span>
    </div>

    <div>
      <strong>Month:</strong>
      <span><%= @salary_slip.month %></span>
    </div>

    <div>
      <strong>Year:</strong>
      <span><%= @salary_slip.year %></span>
    </div>

  </div>


  <!-- EARNINGS AND DEDUCTIONS -->

  <div class="salary-section">

    <!-- EARNINGS -->

    <div class="salary-box">

      <h3>Earnings</h3>

      <div class="salary-row">
        <span>Basic Salary</span>
        <span>₹ <%= @salary_slip.basic_salary %></span>
      </div>

      <div class="salary-row">
        <span>HRA</span>
        <span>₹ <%= @salary_slip.hra %></span>
      </div>

      <div class="salary-row">
        <span>Transport Allowance</span>
        <span>₹ <%= @salary_slip.transport_allowance %></span>
      </div>

      <div class="salary-row">
        <span>Medical Allowance</span>
        <span>₹ <%= @salary_slip.medical_allowance %></span>
      </div>

      <div class="salary-row">
        <span>Special Allowance</span>
        <span>₹ <%= @salary_slip.special_allowance %></span>
      </div>

      <div class="salary-row">
        <span>Other Allowances</span>
        <span>₹ <%= @salary_slip.other_allowances %></span>
      </div>

      <div class="salary-row total-row">
        <span>Gross Salary</span>
        <span>₹ <%= @salary_slip.gross_salary %></span>
      </div>

    </div>


    <!-- DEDUCTIONS -->

    <div class="salary-box">

      <h3>Deductions</h3>

      <div class="salary-row">
        <span>Provident Fund (PF)</span>
        <span>₹ <%= @salary_slip.pf %></span>
      </div>

      <div class="salary-row">
        <span>Professional Tax</span>
        <span>₹ <%= @salary_slip.professional_tax %></span>
      </div>

      <div class="salary-row">
        <span>TDS</span>
        <span>₹ <%= @salary_slip.tds %></span>
      </div>

      <div class="salary-row">
        <span>Loan Deduction</span>
        <span>₹ <%= @salary_slip.loan_deduction %></span>
      </div>

      <div class="salary-row">
        <span>Other Deductions</span>
        <span>₹ <%= @salary_slip.other_deductions %></span>
      </div>

      <div class="salary-row total-row">
        <span>Total Deductions</span>
        <span>₹ <%= @salary_slip.deductions %></span>
      </div>

    </div>

  </div>


  <!-- NET SALARY -->

  <div class="net-salary">

    Net Salary:
    ₹ <%= @salary_slip.net_salary %>

  </div>


  <!-- FOOTER -->

  <div class="footer">

    <p>This is a computer-generated salary slip.</p>

    <p>Hjort Knudsen Pvt. Ltd.</p>

  </div>

</div>


<!-- ACTION BUTTONS -->

<div class="action-buttons">

  <%= link_to "← Back to Dashboard",
              employee_dashboard_path,
              class: "back-button" %>


  <div class="print-button">

    <button onclick="window.print()">
      Print / Save as PDF
    </button>

  </div>

</div>