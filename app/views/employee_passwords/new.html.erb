<style>
body{
  font-family:Arial,sans-serif;
  background:#f4f6f9;
}

.password-container{
  width:420px;
  margin:80px auto;
}

.password-box{
  background:white;
  padding:35px;
  border-radius:15px;
  box-shadow:0 4px 12px rgba(0,0,0,.08);
}

.password-box h1{
  text-align:center;
  margin-bottom:30px;
  color:#1f2937;
}

.form-group{
  margin-bottom:20px;
}

.form-group label{
  display:block;
  font-weight:bold;
  margin-bottom:8px;
}

.form-group input{
  width:100%;
  padding:12px;
  border:1px solid #d1d5db;
  border-radius:8px;
}

.submit-button{
  width:100%;
  padding:13px;
  background:#2563eb;
  color:white;
  border:none;
  border-radius:8px;
  font-size:16px;
  cursor:pointer;
}

.submit-button:hover{
  background:#1d4ed8;
}

.error{
  color:red;
  text-align:center;
  margin-bottom:15px;
}
</style>

<div class="password-container">

<div class="password-box">

<h1>Change Password</h1>

<% if flash[:alert] %>
  <div class="error">
    <%= flash[:alert] %>
  </div>
<% end %>

<%= form_with url: change_password_path, method: :patch do %>

<div class="form-group">
<label>New Password</label>
<%= password_field_tag :password %>
</div>

<div class="form-group">
<label>Confirm Password</label>
<%= password_field_tag :password_confirmation %>
</div>

<%= submit_tag "Update Password",
class:"submit-button" %>

<% end %>

</div>

</div>